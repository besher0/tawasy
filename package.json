{
  "name": "sugarprecision-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "SugarPrecision production management monorepo (NestJS + React Native)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "bootstrap": "npm install --workspaces",
    "build": "npm run build --workspace @sugarprecision/api && npm run typecheck --workspace @sugarprecision/mobile",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev:api": "npm run start:dev --workspace @sugarprecision/api",
    "dev:mobile": "npm run start --workspace @sugarprecision/mobile",
    "build:windows": "npm run build --workspace @sugarprecision/windows",
    "db:migrate": "npm run prisma:migrate --workspace @sugarprecision/api",
    "db:generate": "npm run prisma:generate --workspace @sugarprecision/api"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
