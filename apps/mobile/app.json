{
  "expo": {
    "name": "Tawasy",
    "slug": "tawasy",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#f4faff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tawasy.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#f4faff"
      },
      "package": "com.sugarprecision.app"
    },
    "extra": {
      "apiBaseUrl": "${EXPO_PUBLIC_API_BASE_URL}",
      "eas": {
        "projectId": "9ac2b71f-eb5e-4540-b345-3a0db95686e7"
      }
    },
    "owner": "besher1",
    "plugins": [
      "expo-font"
    ],
    "updates": {
      "url": "https://u.expo.dev/9ac2b71f-eb5e-4540-b345-3a0db95686e7"
    }
  }
}
